# ============================================================
# Configuração do Sistema de Inventário de TI
# Copie este arquivo para ".env" e ajuste os valores.
# ============================================================

# Ambiente de execução: development | production
FLASK_ENV=development

# Chave secreta usada por sessões, cookies e Flask-Login.
# Gere uma nova com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-aleatoria-e-secreta

# String de conexão do banco MySQL (driver PyMySQL).
# Formato: mysql+pymysql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/inventory_db

# ============================================================
# E-mail (SMTP) — alertas de vencimento de certificados
# Padrão: Google Workspace / Gmail.
# IMPORTANTE: com Gmail/Workspace use uma "Senha de app" (App Password),
# não a senha normal da conta (exige verificação em 2 etapas ativada).
# ============================================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=ti@suaempresa.com.br
MAIL_PASSWORD=senha-de-app-de-16-digitos
# Remetente exibido (opcional; se vazio usa MAIL_USERNAME).
MAIL_FROM=ti@suaempresa.com.br
MAIL_FROM_NAME=Centralizador de TI
# Cópia fixa opcional em todo alerta (ex.: lista do time). Deixe vazio se não usar.
MAIL_ALERT_EXTRA=
