# ============================================================
# Configuração do Sistema de Inventário de TI
# Copie este arquivo para ".env" e ajuste os valores.
# ============================================================

# Ambiente de execução: development | production
FLASK_ENV=development

# Chave secreta usada por sessões, cookies e Flask-Login.
# Gere uma nova com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-aleatoria-e-secreta

# String de conexão do banco MySQL (driver PyMySQL).
# Formato: mysql+pymysql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/inventory_db
